# Resend — transactional email for contact form (Phase 6)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address (domain must be verified in Resend dashboard)
RESEND_FROM_EMAIL=
# Destination for contact form submissions
CONTACT_TO_EMAIL=

# Cloudflare Turnstile — optional bot protection on contact form (Phase 6)
# Leave unset to disable; site falls back to honeypot only
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Site origin — used for sitemap, OG image absolute URLs, JSON-LD (Phase 3, 7)
NEXT_PUBLIC_SITE_URL=https://mpairwe.dev
